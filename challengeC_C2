#include <Arduino_FreeRTOS.h>
#include <MultiFunctionShield.h>
#include <semphr.h>

void Task1(void *pvParameters);
void Task2(void *pvParameters);
void TaskButtons(void *pvParameters);
void TaskDisplay(void *pvParameters);

MultiFunctionShield MFS;

int counter = 0;
SemaphoreHandle_t binSem; 

// control variables
bool task1Active = true;
bool task2Active = true;

void setup() {

  MFS.begin();
  Serial.begin(9600);

  pinMode(LED_1_PIN, OUTPUT);
  pinMode(LED_2_PIN, OUTPUT);

  digitalWrite(LED_1_PIN, HIGH);
  digitalWrite(LED_2_PIN, HIGH);

  xTaskCreate(Task1, "Task1", 128, NULL, 1, NULL);
  xTaskCreate(Task2, "Task2", 128, NULL, 1, NULL);
  xTaskCreate(TaskButtons, "Buttons", 128, NULL, 1, NULL);
  binSem = xSemaphoreCreateBinary();


  xTaskCreate(TaskDisplay, "Display", 128, NULL, 2, NULL); // alta prioridade

  vTaskStartScheduler();
}

void Task1(void *pvParameters)
{
  while(1)
  {
    if(task1Active)
    {
      counter++;
      digitalWrite(LED_1_PIN, HIGH);
      vTaskDelay(random(100,2000)/portTICK_PERIOD_MS);
    }
    else
    {
      digitalWrite(LED_1_PIN, LOW);
      vTaskDelay(100/portTICK_PERIOD_MS);
    }
    xSemaphoreGive(binSem);
  }
}

void Task2(void *pvParameters)
{
  while(1)
  {
    if(task2Active)
    {
      counter++;
      digitalWrite(LED_2_PIN, HIGH);
      vTaskDelay(random(100,2000)/portTICK_PERIOD_MS);
    }
    else
    {
      digitalWrite(LED_2_PIN, LOW);
      vTaskDelay(100/portTICK_PERIOD_MS);
    }
    xSemaphoreGive(binSem);
  }
}

void TaskButtons(void *pvParameters)
{
  while(1)
  {
    if(!digitalRead(BUTTON_1_PIN))
    {
      task1Active = !task1Active;   // toggle Task1
      vTaskDelay(300/portTICK_PERIOD_MS);
    }

    if(!digitalRead(BUTTON_2_PIN))
    {
      task2Active = !task2Active;   // toggle Task2
      vTaskDelay(300/portTICK_PERIOD_MS);
    }

    vTaskDelay(50/portTICK_PERIOD_MS);
  }
}

void TaskDisplay(void *pvParameters)
{
  // implementa o semaforo
  while(1)
  {
    if (xSemaphoreTake(binSem, portMAX_DELAY) == pdTRUE){

    MFS.Display(counter);
    vTaskDelay(100/portTICK_PERIOD_MS);
    }
  }
}

void loop(){}
